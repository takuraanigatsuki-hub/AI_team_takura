# ============================================================
# Trade — пример переменных окружения.
# Скопируйте этот файл в `.env` и отредактируйте значения.
# Никогда не коммитьте `.env` в репозиторий.
# ============================================================

APP_NAME=Trade
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# --- База данных (SQLite по умолчанию) ---------------------
DATABASE_URL=sqlite:///./data/trade.db

# --- Биржа / режим работы ----------------------------------
# Поддерживается любая биржа из ccxt: binance, bybit, okx, kraken, coinbase, ...
EXCHANGE_ID=binance
# Базовая котировочная валюта для отчётности.
QUOTE_CURRENCY=USDT
# Торговые пары через запятую — какие инструменты бот будет анализировать.
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
# Таймфрейм свечей: 1m, 5m, 15m, 1h, 4h, 1d ...
TIMEFRAME=15m
# Период опроса биржи в секундах.
LOOP_INTERVAL_SECONDS=30

# --- Режим работы ------------------------------------------
# paper  — виртуальные деньги, реальные цены (безопасно, по умолчанию)
# live   — реальные ордера через API биржи (включается ОСОЗНАННО)
MODE=paper
# Стартовый баланс в paper-режиме (в QUOTE_CURRENCY).
PAPER_STARTING_BALANCE=10000

# --- Реальные API-ключи биржи (ТОЛЬКО для live) ------------
# Создавайте ключи С ПРАВОМ TRADE, БЕЗ ПРАВА WITHDRAW.
# Желательно с привязкой к IP.
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
# Для bybit/okx обычно требуется ещё:
EXCHANGE_API_PASSWORD=
EXCHANGE_TESTNET=false

# --- Риск-менеджмент ---------------------------------------
# Доля капитала на одну сделку (0.05 = 5%).
RISK_PER_TRADE=0.05
# Максимум одновременно открытых позиций.
MAX_OPEN_POSITIONS=3
# Стоп-лосс / тейк-профит в долях от цены входа.
STOP_LOSS_PCT=0.03
TAKE_PROFIT_PCT=0.06
# Максимально допустимый дневной убыток (0.05 = 5% капитала).
# При достижении бот блокирует новые сделки до начала следующего дня UTC.
DAILY_LOSS_LIMIT_PCT=0.05
# Минимальный размер ордера в QUOTE_CURRENCY.
MIN_ORDER_NOTIONAL=10

# --- Активные стратегии (через запятую) --------------------
# Доступно: ma_crossover, rsi_reversion, bollinger_breakout, llm_advisor
STRATEGIES=ma_crossover,rsi_reversion,bollinger_breakout
# Минимум согласных стратегий, чтобы открыть сделку (1 = любая, 2 = большинство).
SIGNAL_CONSENSUS=2

# --- LLM-советник + автономный агент -----------------------
# Если ключ пустой — LLM-функционал отключается (стратегия и агент бездействуют).
# Поддерживаются OpenAI-совместимые API: OpenAI, OpenRouter, локальные shim'ы.
#
# Топовые модели по reasoning (рекомендуется для трейдинга):
#   OpenAI:        gpt-5.4-high, gpt-5.5-high, gpt-5.3-codex-high
#   Anthropic:     claude-opus-4.8, claude-opus-4.7, claude-4.6-sonnet
#   OpenRouter:    anthropic/claude-opus-4.8, openai/gpt-5.4-high, etc.
#
# Для локального инференса (Ollama / LM Studio / vLLM):
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=llama3.3:70b-instruct  (или ваша модель)
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-5.4-high
LLM_BASE_URL=
# Native function-calling (tools API) для агента. На моделях, которые
# не поддерживают tools — автоматический fallback в JSON-mode.
LLM_USE_TOOLS=true

# --- Автономный ИИ-агент (Project-Vend-style) --------------
# Если AGENT_ENABLED=true и LLM_API_KEY задан — агент стартует автоматически.
# Иначе включается вручную с дашборда.
AGENT_ENABLED=false
AGENT_INTERVAL_SECONDS=600
AGENT_MAX_ACTIONS_PER_CYCLE=3
AGENT_NEWS_PER_CYCLE=8
AGENT_JOURNAL_LOOKBACK=6
AGENT_TEMPERATURE=0.2
AGENT_MAX_TOKENS=1500

# --- Reflection (агент учится на собственных решениях) -----
# Раз в N часов агент перечитывает свой дневник, оценивает результат
# каждой сделки и пишет себе memo с уроками. Memo подмешивается в
# контекст следующих циклов.
REFLECTION_ENABLED=true
REFLECTION_INTERVAL_HOURS=12
REFLECTION_JOURNAL_LOOKBACK=30
REFLECTION_MAX_TOKENS=800
REFLECTION_TEMPERATURE=0.4

# --- Безопасность веб-панели -------------------------------
# Простой Basic Auth. Если пусто — доступ открыт (ставьте только локально).
WEB_USER=
WEB_PASSWORD=

# --- Telegram-бот (опционально, но рекомендую) -------------
# 1) Создайте бота у @BotFather → получите токен (123456:ABC...)
# 2) Напишите боту /start, затем откройте https://api.telegram.org/bot<TOKEN>/getUpdates
#    и найдите ваш chat.id (целое число) — впишите его в TELEGRAM_CHAT_ID.
#    Только этот чат сможет давать команды; остальные будут отклоняться.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_ORDERS=true
TELEGRAM_NOTIFY_AGENT=true
TELEGRAM_NOTIFY_ERRORS=true
TELEGRAM_DAILY_SUMMARY_HOUR_UTC=9
