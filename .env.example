# Скопируйте в .env и подставьте свои значения
CURSOR_API_KEY=crsr_your_key_here
CURSOR_REPO_URL=https://github.com/takuraanigatsuki-hub/AI_team_takura

# LLM — реальные ответы агентов (OpenAI-compatible)
# Вариант A: OpenAI
# OPENAI_API_KEY=sk-your_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Вариант B: Smart AIPI (drop-in, тот же формат API)
OPENAI_API_KEY=sk-your_smart_aipi_key
OPENAI_BASE_URL=https://api.smartaipi.com/v1
LLM_MODEL=gpt-5.4-mini
LLM_ROUTER_MODEL=gpt-5.4-nano
EMBEDDING_MODEL=text-embedding-3-small

# Опциональная защита API (заголовок X-API-Key)
ROOM_API_KEY=

# Figma — OAuth (рекомендуется) или Personal Access Token
FIGMA_CLIENT_ID=your_oauth_client_id
FIGMA_CLIENT_SECRET=your_oauth_client_secret
FIGMA_REDIRECT_URI=http://localhost:8000/api/figma/callback
FIGMA_ACCESS_TOKEN=figd_your_token_here

# Telegram (бот управления + уведомления)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLLING=true

# Jira / Linear / Notion / Vercel (опционально)
JIRA_URL=
JIRA_TOKEN=
JIRA_EMAIL=
JIRA_PROJECT=PROJ
LINEAR_API_KEY=
LINEAR_TEAM_ID=
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
VERCEL_TOKEN=

# Microsoft 365 — Graph API (таблицы Excel, Word, презентации в OneDrive)
MS365_TENANT_ID=
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=
MS365_USER_EMAIL=you@company.onmicrosoft.com
MS365_FOLDER=AI Team Room
GITHUB_TOKEN=
CONTEXT7_API_KEY=
SENTRY_ACCESS_TOKEN=
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=
DATABASE_URL=
SQLITE_DB_PATH=data/ai_team.sqlite

# Stripe — оплата подписок (включите feature flag stripe_billing в Admin)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
