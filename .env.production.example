# ═══════════════════════════════════════════════════════════════
# PRODUCTION — скопируйте на VPS как .env
# cp .env.production.example .env && nano .env
# ═══════════════════════════════════════════════════════════════

# ── 1. ДОМЕН (DNS A-запись → IP VPS) ─────────────────────────
APP_DOMAIN=room.ВАШ-ДОМЕН.ru

# ── 2. LLM (Smart AIPI или OpenAI) ─────────────────────────────
# Где взять: https://smartaipi.com или platform.openai.com
OPENAI_API_KEY=sk-ВАШ_КЛЮЧ
OPENAI_BASE_URL=https://api.smartaipi.com/v1
LLM_MODEL=gpt-5.4-mini
LLM_ROUTER_MODEL=gpt-5.4-nano
EMBEDDING_MODEL=text-embedding-3-small

# ── 3. База на сервере (Docker postgres) ─────────────────────
POSTGRES_USER=aiteam
POSTGRES_PASSWORD=ПРИДУМАЙТЕ_ДЛИННЫЙ_ПАРОЛЬ
POSTGRES_DB=aiteam
DATABASE_URL=postgresql://aiteam:ПРИДУМАЙТЕ_ДЛИННЫЙ_ПАРОЛЬ@postgres:5432/aiteam
SQLITE_DB_PATH=data/ai_team.sqlite

# ── 4. GitHub / Cursor ─────────────────────────────────────────
# Cursor: cursor.com → Settings → API Keys
CURSOR_API_KEY=crsr_ВАШ_КЛЮЧ
CURSOR_REPO_URL=https://github.com/takuraanigatsuki-hub/AI_team_takura
# GitHub: github.com → Settings → Developer settings → PAT
GITHUB_TOKEN=ghp_ВАШ_ТОКЕН

# ── 5. Figma (Design Lab) ─────────────────────────────────────
# figma.com → Settings → OAuth apps → Redirect URI:
#   https://room.ВАШ-ДОМЕН.ru/api/figma/callback
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
FIGMA_REDIRECT_URI=https://room.ВАШ-ДОМЕН.ru/api/figma/callback
FIGMA_ACCESS_TOKEN=

# ── 6. Telegram (опционально) ─────────────────────────────────
# @BotFather → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_POLLING=true

# ── 7. Бэкап в облако (опционально) ───────────────────────────
# rclone config → remote "gdrive:"
# RCLONE_REMOTE=gdrive:AI_team_backups

# ── 8. Локально на VPS не нужно ───────────────────────────────
OUTBOUND_PROXY_MODE=off
OUTBOUND_PROXY=

# ── Остальное — по необходимости (Stripe, M365, Jira…) ────────
ROOM_API_KEY=
