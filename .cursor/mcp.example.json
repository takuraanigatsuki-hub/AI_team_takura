{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github@0.6.2"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
      }
    },
    "figma": {
      "command": "npx",
      "args": ["-y", "figma-developer-mcp@0.6.3", "--stdio"],
      "env": {
        "FIGMA_API_KEY": "${env:FIGMA_ACCESS_TOKEN}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@0.0.36"]
    },
    "linear": {
      "url": "https://mcp.linear.app/mcp"
    },
    "atlassian-jira": {
      "command": "npx",
      "args": ["-y", "mcp-remote@0.1.18", "https://mcp.atlassian.com/v1/mcp/authv2"]
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server@2.0.0"],
      "env": {
        "NOTION_TOKEN": "${env:NOTION_TOKEN}"
      }
    },
    "vercel": {
      "url": "https://mcp.vercel.com"
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${env:CONTEXT7_API_KEY}"
      }
    },
    "sqlite": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sqlite@0.6.2",
        "${env:SQLITE_DB_PATH}"
      ]
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres@0.6.2",
        "${env:DATABASE_URL}"
      ]
    },
    "sentry": {
      "url": "https://mcp.sentry.dev/mcp",
      "headers": {
        "Authorization": "Bearer ${env:SENTRY_ACCESS_TOKEN}"
      }
    },
    "docker": {
      "command": "uvx",
      "args": ["mcp-server-docker@0.2.0"]
    },
    "slack": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack@0.6.2"],
      "env": {
        "SLACK_BOT_TOKEN": "${env:SLACK_BOT_TOKEN}",
        "SLACK_TEAM_ID": "${env:SLACK_TEAM_ID}"
      }
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory@0.6.2"]
    }
  }
}
